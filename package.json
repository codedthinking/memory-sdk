{
  "name": "@codedthinking/memory-sdk",
  "version": "0.1.0",
  "description": "Thin provider-agnostic wrapper for AI memory backends",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "import": "./dist/providers/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "memory",
    "ai",
    "agents",
    "everos",
    "hindsight",
    "nams",
    "zep"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codedthinking/memory-sdk.git"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.8.0"
  }
}
